{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "pkgs": ["nodejs@22", "pnpm@10"]
        },
        "build": {
          "cmds": [
            "corepack enable",
            "pnpm install --frozen-lockfile",
            "pnpm --filter pptpxgenjs build"
          ]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "pnpm --filter pptpxgenjs start",
    "restartPolicyType": "ON_FAILURE"
  }
}
